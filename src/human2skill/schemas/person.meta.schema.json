{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "slug", "display_name", "profile_type", "voice_mode", "privacy_policy", "export_policy", "lifecycle"],
  "properties": {
    "schema_version": {"const": "1"},
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "display_name": {"type": "string", "minLength": 1},
    "profile_type": {"enum": ["colleague", "relationship", "mentor", "self"]},
    "relationship_to_user": {"type": "string"},
    "use_case": {"type": "string"},
    "voice_mode": {"enum": ["advisor", "first_person", "both"]},
    "consent_status": {
      "type": "object",
      "required": ["person_consented", "distribution_allowed"],
      "properties": {
        "person_consented": {"type": "boolean"},
        "distribution_allowed": {"type": "boolean"},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    },
    "privacy_policy": {
      "type": "object",
      "required": ["raw_retention", "public_skill_allows_private_quotes"],
      "properties": {
        "raw_retention": {"enum": ["no_raw_retention", "summary_only", "local_private_raw"]},
        "public_skill_allows_private_quotes": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "export_policy": {
      "type": "object",
      "required": ["default_visibility", "shareable_variants", "requires_privacy_review"],
      "properties": {
        "default_visibility": {"enum": ["private", "shared", "public"]},
        "shareable_variants": {
          "type": "array",
          "items": {"enum": ["advisor", "first_person"]}
        },
        "requires_privacy_review": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["version", "created_at", "updated_at"],
      "properties": {
        "version": {"type": "string", "pattern": "^v[0-9]+$"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": {"voice_mode": {"const": "advisor"}}
  },
  "then": {
    "properties": {
      "privacy_policy": {
        "properties": {
          "public_skill_allows_private_quotes": {"const": false}
        }
      }
    }
  }
}
