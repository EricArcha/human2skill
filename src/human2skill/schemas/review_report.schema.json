{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "person_slug", "variant", "generated_at", "passed", "hard_failures", "scores", "required_changes", "notes"],
  "properties": {
    "schema_version": {"const": "1"},
    "person_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "variant": {"enum": ["advisor", "first_person"]},
    "generated_at": {"type": "string", "format": "date-time"},
    "passed": {"type": "boolean"},
    "hard_failures": {
      "type": "array",
      "items": {"type": "string"}
    },
    "scores": {
      "type": "object",
      "required": ["evidence_consistency", "confidence_calibration", "honest_boundary", "privacy_safety", "expression_similarity", "thinking_utility", "profile_fit"],
      "properties": {
        "evidence_consistency": {"type": "integer", "minimum": 1, "maximum": 5},
        "confidence_calibration": {"type": "integer", "minimum": 1, "maximum": 5},
        "honest_boundary": {"type": "integer", "minimum": 1, "maximum": 5},
        "privacy_safety": {"type": "integer", "minimum": 1, "maximum": 5},
        "expression_similarity": {"type": "integer", "minimum": 1, "maximum": 5},
        "thinking_utility": {"type": "integer", "minimum": 1, "maximum": 5},
        "profile_fit": {"type": "integer", "minimum": 1, "maximum": 5}
      },
      "additionalProperties": false
    },
    "required_changes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}
