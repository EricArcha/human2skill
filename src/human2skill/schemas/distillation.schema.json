{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "person_slug", "generated_at", "source_evidence_pack_version", "mental_models", "decision_heuristics", "expression_dna", "profile_specific", "pressure_response", "value_order", "anti_patterns", "honest_boundaries", "scenario_tests"],
  "properties": {
    "schema_version": {"const": "1"},
    "person_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_evidence_pack_version": {"type": "string", "pattern": "^v[0-9]+$"},
