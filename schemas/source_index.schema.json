{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "person_slug", "sources"],
  "properties": {
    "schema_version": {"const": "1"},
    "person_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "source_kind", "title", "provided_by", "retention", "contains_private_data", "allowed_in_public_skill", "summary", "created_at"],
        "properties": {
          "source_id": {"type": "string", "pattern": "^src-[0-9]{4}$"},
          "source_kind": {
            "enum": ["manual_text", "markdown", "txt", "pdf_text", "chat_excerpt", "meeting_note", "email_summary", "interview_answer", "screenshot_text"]
          },
          "title": {"type": "string", "minLength": 1},
          "provided_by": {"type": "string"},
          "retention": {"enum": ["no_raw_retention", "summary_only", "local_private_raw"]},
          "contains_private_data": {"type": "boolean"},
          "allowed_in_public_skill": {"type": "boolean"},
          "summary": {"type": "string", "minLength": 1},
          "created_at": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
